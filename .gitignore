# dependencies
node_modules
.pnp
.pnp.js

# testing
coverage
tooling/scripts/metrics/

# next.js
.next/
out/
build
.swc/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files (per-app convention)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
apps/web/.env
apps/web/.env.local
apps/web/.env.development.local
apps/web/.env.test.local
apps/web/.env.production.local

# Production-credential containers — block anywhere in the tree.
# Patterns deliberately broad: a false positive is fine, a leaked .env.prod
# is not. The admin CLI stores its secrets under tooling/admin/.secrets/.
**/.secrets/
**/.creds/
**/prod.env
**/production.env
**/preview.env
**/staging.env
**/.env.prod
**/.env.production
**/.env.preview
**/.env.staging

# turbo
.turbo

# ui
dist/

# typescript
*.tsbuildinfo

# other
.react-email/
.content-collections/
.vercel

# stale Supabase CLI cache (Supabase has been replaced by Docker Compose + Neon)
supabase/

# worktrees
.worktrees/

# storybook
storybook-static/
